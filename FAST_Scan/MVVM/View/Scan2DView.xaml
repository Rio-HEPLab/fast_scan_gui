<UserControl x:Class="FAST_Scan.MVVM.View.Scan2DView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FAST_Scan.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="3*"
                           MinHeight="220"/>
            <RowDefinition Height="2*"
                           MaxHeight="80"
                           MinHeight="60"/>
            <RowDefinition Height="1*"
                           MinHeight="50"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Configure 2D Scan"
                   Grid.Row="0"
                   FontSize="25"
                   HorizontalAlignment="Center"
                   FontFamily="Bahnschrift Bold"
                   Foreground="#4053A0"
                   VerticalAlignment="Top"
                   Margin="10"/>


        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition MinHeight="40"/>
                <RowDefinition MinHeight="40"/>
                <RowDefinition MinHeight="40"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0"
                        Margin="5">
                <TextBlock Text="X Initial Position (mm)"
                            HorizontalAlignment="Center"/>

                <TextBox Name="xStartTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="NumbersOnly_PreviewTextInput" TextChanged="xStartTB_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Margin="5">
                <TextBlock Text="Y Initial Position (mm)"
                            HorizontalAlignment="Center"/>

                <TextBox Name="yStartTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"                         
                         Height="20"
                         PreviewTextInput="NumbersOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Margin="5">
                <TextBlock Text="Digitizer Samples"
                            HorizontalAlignment="Center"/>
                <TextBox Name="digitizerSamplesTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Margin="5">
                <TextBlock Text="X Final Position (mm)"
                            HorizontalAlignment="Center"/>

                <TextBox Name="xStopTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="NumbersOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
            Grid.Column="1"
            Margin="5">
                <TextBlock Text="Y Final Position (mm)"
                           HorizontalAlignment="Center"/>

                <TextBox Name="yStopTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="NumbersOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        Margin="5">
                <TextBlock Text="Pulse Polarity"
                           HorizontalAlignment="Center"/>

                <ComboBox Name="PulsePolarityCB"
                          HorizontalAlignment="Stretch"
                          MaxWidth="250"
                          Margin="10,0,10,10"/>
            </StackPanel>

            <StackPanel Grid.Row="0"
            Grid.Column="2"
            Margin="5">
                <TextBlock Text="X Number of Steps"
                            HorizontalAlignment="Center"/>

                <TextBox Name="xStepsTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Grid.Column="2"
                        Margin="5">
                <TextBlock Text="Y Number of Steps"
                            HorizontalAlignment="Center"/>

                <TextBox Name="yStepsTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="2"
                        Margin="5">
                <TextBlock Text="Z Position (mm)"
                            HorizontalAlignment="Center"/>
                <TextBox Name="zPositionTB"
                         HorizontalAlignment="Stretch"
                         MaxWidth="250"
                         Margin="10,0,10,10"
                         Height="20"
                         PreviewTextInput="DigitsOnly_PreviewTextInput"
                         IsEnabled="{Binding IsChecked, ElementName=zSetCB}"/>
                <CheckBox Name="zSetCB"
                          Content="Set Z Position"
                          Margin="0,0,0,5"
                          HorizontalAlignment="Center"
                          Grid.Column="2"
                          Grid.Row="3"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2"
      VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition MinWidth="200"
                          MaxWidth="500"
                          Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" 
                Text="Save File as"
                Margin="0,0,5,0"
                VerticalAlignment="Center"
               HorizontalAlignment="Right"/>
            <TextBox Grid.Column="1"
                Name="saveFileTB"
                Height="25"
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"/>

            <Button Grid.Column="2"
        Name="BrowseButton"
            Content="Browse"
            Width="70"
            Height="25"
            Margin="0,0,5,0"
            Click="Browse_Click"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"/>

            <CheckBox Grid.ColumnSpan="3"
            Name="GenerateImageCB"
            Grid.Row="1"
            HorizontalAlignment="Center"
            Margin="5"
            Content="Generate image after scan is completed"/>

        </Grid>

        <Grid Grid.Row="3"
        VerticalAlignment="Bottom"
      Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="105"/>
                <ColumnDefinition MinWidth="105"/>
                <ColumnDefinition/>
                <ColumnDefinition MinWidth="105"/>
                <ColumnDefinition MinWidth="105"/>
            </Grid.ColumnDefinitions>

            <Button Name="HomeButton"
            Content="Home" 
            Click="HomeButton_Click"
            Grid.Column="0"
            Height="25"
            MinWidth="80"
            MaxWidth="150"
            HorizontalAlignment="Stretch"
            Margin="10"/>

            <Button Name="ClearParametersButton"
            Content="Reset Inputs "
            Click="ClearParametersButton_Click"
            Grid.Column="1"
            MinWidth="80"
            MaxWidth="150"
            HorizontalAlignment="Stretch"
            Margin="10"/>

            <Button Name="StartScanButton"
            Content="Start Scan" 
            Click="StartScanButton_Click"
            Grid.Column="3"
            MinWidth="80"
            MaxWidth="150"
            HorizontalAlignment="Stretch"
            Margin="10"/>

            <Button Name="StopScanButton"
            Content="Stop Scan" 
            Click="StopScanButton_Click"
            Grid.Column="4"
            MinWidth="80"
            MaxWidth="150"
            HorizontalAlignment="Stretch"
            Margin="10"/>

            <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Left"
                Grid.Column="1" Height="20" Margin="100,0,0,0" VerticalAlignment="Top">


            </StackPanel>
        </Grid>

    </Grid>

</UserControl>
