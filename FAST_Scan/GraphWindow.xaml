<Window x:Class="FAST_Scan.GraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FAST_Scan" xmlns:scottPlot="http://schemas.scottplot.net/2008/xaml/presentation"
        xmlns:viewModel="clr-namespace:FAST_Scan.MVVM.ViewModel"
        mc:Ignorable="d"
        Title="GraphWindow" Height="450" Width="800">
    <Window.DataContext>
        <viewModel:GraphViewModel/>
    </Window.DataContext>
    <Grid>
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>
